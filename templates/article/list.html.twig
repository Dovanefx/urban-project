{% extends "base.html.twig" %}

{% block title %}Articles - Urban Project{% endblock %}

{% block body %}
<h1>Articles</h1>
<a href="{{ path('article_new') }}"><button>Ajouter un article</button></a>

{% if articles|length > 0 %}
    <table>
        <tr>
            <th>ID</th>
            <th>Titre</th>
            <th>Actions</th>
        </tr>
        {% for article in articles %}
            <tr>
                <td>{{ article.id }}</td>
                <td>{{ article.titre }}</td>
                <td>
                    <a href="{{ path('article_edit', {id: article.id}) }}"><button>Modifier</button></a>
                    <form method="POST" action="{{ path('article_delete', {id: article.id}) }}" style="display:inline;" onsubmit="return confirm('Sûr?');">
                        <button type="submit" class="danger">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% endfor %}
    </table>
{% else %}
    <p>Aucun article trouvé.</p>
{% endif %}
{% endblock %}
