{% extends "base.html.twig" %}

{% block title %}Ajouter Citoyen - Urban Project{% endblock %}

{% block body %}
<h1>Ajouter un citoyen</h1>

<form method="POST">
    <label>Nom:</label>
    <input type="text" name="nom" required>
    
    <label>Email:</label>
    <input type="email" name="email" required>
    
    <button type="submit">Ajouter</button>
    <a href="{{ path('citoyen_list') }}"><button type="button">Annuler</button></a>
</form>
{% endblock %}
